# Pin for the Android eSpeak NG bundle consumed by android-build.yml /
# android-release-build.yml. Updated each time .github/workflows/espeak-android-bundle.yml
# publishes a new tarball.
#
#   BUNDLE_TAG     — GitHub release tag holding the asset.
#   BUNDLE_ASSET   — Asset filename inside that release.
#   BUNDLE_SHA256  — Expected sha256 of the asset (verified at consume time).
#   ESPEAK_NG_REF  — Upstream eSpeak NG ref the bundle was built from (informational).

BUNDLE_TAG=espeak-android-bundle-v1
BUNDLE_ASSET=kokoro-espeak-android-bundle.tar.gz
BUNDLE_SHA256=52a86e645042f70d676ed2df36a71379256343d72b0ad4d1470618df3a937a77
ESPEAK_NG_REF=master
